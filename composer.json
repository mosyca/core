{
    "name": "mosyca/core",
    "description": "Mosyca Core – PHP/Symfony framework for MCP-native, self-documenting API plugins",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "Roland Urban",
            "email": "roland@mosyca.com",
            "homepage": "https://mosyca.dev"
        }
    ],
    "keywords": ["mcp", "api", "plugin", "symfony", "shopware", "cli", "openapi"],
    "homepage": "https://mosyca.dev",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mosyca\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mosyca\\Core\\Tests\\": "tests/",
            "Mosyca\\Core\\Examples\\": "examples/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
